{
  "id": "b6f2a9c4-3d71-4e58-9a10-2c5f7e8d4b31",
  "name": "pacheck",
  "friendlyName": "pacheck (Power Apps canvas lint)",
  "description": "Run pacheck lint over Power Apps canvas source and publish SARIF.",
  "helpMarkDown": "See https://github.com/pacheck/pacheck",
  "category": "Utility",
  "author": "pacheck contributors",
  "version": { "Major": 0, "Minor": 1, "Patch": 0 },
  "instanceNameFormat": "pacheck lint $(path)",
  "inputs": [
    {
      "name": "path",
      "type": "string",
      "label": "App path",
      "defaultValue": ".",
      "required": true,
      "helpMarkDown": "Unpacked pa.yaml folder or a .msapp file."
    },
    {
      "name": "format",
      "type": "pickList",
      "label": "Output format",
      "defaultValue": "sarif",
      "options": { "console": "console", "json": "json", "sarif": "sarif", "html": "html" }
    },
    {
      "name": "failOn",
      "type": "pickList",
      "label": "Fail on severity",
      "defaultValue": "warning",
      "options": { "info": "info", "warning": "warning", "error": "error" }
    },
    {
      "name": "output",
      "type": "string",
      "label": "Output file",
      "defaultValue": "$(Build.ArtifactStagingDirectory)/pacheck.sarif"
    },
    {
      "name": "version",
      "type": "string",
      "label": "pacheck version",
      "defaultValue": "",
      "helpMarkDown": "Leave blank for latest."
    }
  ],
  "execution": {
    "PowerShell3": { "target": "pacheck.ps1" }
  }
}
