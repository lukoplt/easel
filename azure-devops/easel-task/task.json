{
  "id": "b6f2a9c4-3d71-4e58-9a10-2c5f7e8d4b31",
  "name": "easel",
  "friendlyName": "easel (Power Apps canvas lint)",
  "description": "Run easel lint over Power Apps canvas source and publish SARIF.",
  "helpMarkDown": "See https://github.com/lukoplt/easel",
  "category": "Utility",
  "author": "easel contributors",
  "version": { "Major": 0, "Minor": 1, "Patch": 5 },
  "instanceNameFormat": "easel lint $(path)",
  "inputs": [
    {
      "name": "path",
      "type": "string",
      "label": "App path",
      "defaultValue": ".",
      "required": true,
      "helpMarkDown": "Unpacked pa.yaml folder or a .msapp file."
    },
    {
      "name": "format",
      "type": "pickList",
      "label": "Output format",
      "defaultValue": "sarif",
      "options": { "console": "console", "json": "json", "sarif": "sarif", "html": "html" }
    },
    {
      "name": "failOn",
      "type": "pickList",
      "label": "Fail on severity",
      "defaultValue": "warning",
      "options": { "info": "info", "warning": "warning", "error": "error" }
    },
    {
      "name": "output",
      "type": "string",
      "label": "Output file",
      "defaultValue": "$(Build.ArtifactStagingDirectory)/easel.sarif"
    },
    {
      "name": "version",
      "type": "string",
      "label": "easel version",
      "defaultValue": "",
      "helpMarkDown": "Leave blank for latest."
    }
  ],
  "execution": {
    "Node20_1": { "target": "index.js" }
  }
}
